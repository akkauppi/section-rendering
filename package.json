{
  "name": "@antti/section-rendering",
  "version": "0.1.0",
  "description": "Dependency-free TypeScript primitives for section projection, surface interfaces, and hidden-line linework.",
  "license": "MIT",
  "private": true,
  "keywords": [
    "geometry",
    "section",
    "projection",
    "hidden-line",
    "svg",
    "dxf"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:examples": "tsc --noEmit -p tsconfig.examples.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "render:three-section-demo": "tsx examples/three-section-svg/render.ts",
    "pack:check": "npm pack --dry-run"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/three": "^0.171.0",
    "three": "^0.171.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
