{
  "name": "@antti/section-rendering",
  "version": "0.1.0",
  "description": "Dependency-free TypeScript primitives for section projection, surface interfaces, and hidden-line linework.",
  "license": "MIT",
  "private": true,
  "keywords": ["geometry", "section", "projection", "hidden-line", "svg", "dxf"],
  "type": "module",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:check": "npm pack --dry-run"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
